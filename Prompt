<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>「觀點LAB」內容架構產生器 V1.1</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .scrollbar-thin::-webkit-scrollbar { width: 6px; height: 6px; }
        .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
        .scrollbar-thin::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .scrollbar-thin::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        .selection-btn {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 10.5pt;
        }
        
        .selection-btn.active {
            border-color: #4f46e5;
            background-color: #eef2ff;
            color: #4338ca;
            font-weight: 600;
            box-shadow: 0 1px 3px rgba(79, 70, 229, 0.1);
            transform: translateY(-1px);
        }

        .selection-btn:not(.active):not(.clear-btn) {
            border-color: #e2e8f0;
            background-color: #ffffff;
            color: #64748b;
        }

        .selection-btn:not(.active):not(.clear-btn):hover {
            border-color: #6366f1;
            background-color: #f8fafc;
            color: #4338ca;
        }

        .clear-btn {
            background-color: #f97316 !important;
            color: white !important;
            border-color: #f97316 !important;
        }
        .clear-btn:hover { background-color: #ea580c !important; }

        .smart-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            color: #6366f1;
            font-weight: 600;
            font-size: 10pt;
        }
        
        body { font-size: 11pt; letter-spacing: -0.01em; }
        pre { font-family: 'Fira Code', 'Cascadia Code', monospace; }
    </style>
</head>
<body class="h-screen bg-slate-50 flex flex-col font-sans text-slate-900 overflow-hidden">

    <!-- Header -->
    <header class="shrink-0 py-3 px-6 border-b border-slate-200 bg-white z-20 shadow-sm flex items-center justify-between">
        <h1 class="text-lg font-black text-slate-800 flex items-center gap-3">
            <span class="bg-indigo-600 text-white px-2 py-0.5 rounded text-xs tracking-widest shadow-sm uppercase">Lab</span>
            觀點LAB <span class="text-slate-400 font-medium text-sm hidden sm:inline border-l pl-3 ml-1 uppercase tracking-tighter">Content Framework Generator V1.1</span>
        </h1>
        <div class="flex items-center gap-3">
            <button id="reset-all-btn" class="text-[10pt] font-bold text-red-500 hover:text-red-700 hover:bg-red-50 px-3 py-1.5 rounded-lg border border-red-100 transition-all active:scale-95 flex items-center gap-2">
                <i data-lucide="rotate-ccw" class="w-4 h-4"></i> 重置
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex overflow-hidden p-2 gap-2" id="container">
        
        <!-- Left Panel: Configurations -->
        <div id="left-panel" class="h-full flex flex-col shrink-0 overflow-hidden border border-slate-200 rounded-xl bg-white shadow-sm" style="flex-basis: 58%;">
            <div class="flex-grow overflow-y-auto p-5 scrollbar-thin">
                <div class="max-w-3xl mx-auto space-y-6" id="config-sections">
                    
                    <!-- Title Input -->
                    <section>
                        <div class="flex items-center justify-between mb-2">
                            <h3 class="text-[10pt] font-bold text-slate-400 uppercase tracking-widest">主題與核心目標</h3>
                            <span class="text-[9pt] text-slate-300 font-mono" id="title-char-count">0 chars</span>
                        </div>
                        <textarea id="title-input" rows="2" placeholder="輸入內容主題，例如：2025 AI 趨勢分析或個人成長策略..." 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-[11pt] outline-none focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-50 transition-all shadow-sm resize-none"></textarea>
                    </section>

                    <!-- Dynamic Selection Groups -->
                    <div id="selection-groups-container" class="space-y-6"></div>
                    
                    <!-- Custom Notes -->
                    <section class="pt-4 border-t border-slate-100">
                        <h3 class="text-[10pt] font-bold text-slate-400 uppercase tracking-widest mb-2">補充細節與特定章節</h3>
                        <textarea id="custom-notes-input" placeholder="有特定的關鍵字、章節要求或風格參考嗎？" 
                            class="w-full h-28 p-4 rounded-xl border border-slate-200 bg-slate-50 text-[11pt] outline-none focus:border-indigo-500 focus:bg-white transition-all resize-none shadow-sm"></textarea>
                    </section>
                </div>
            </div>
        </div>

        <!-- Resizer -->
        <div id="resizer" class="w-1.5 h-32 self-center cursor-col-resize transition-all flex items-center justify-center shrink-0 bg-slate-200 hover:bg-indigo-400 rounded-full mx-[-3px] z-10 group">
            <div class="w-0.5 h-8 bg-slate-400 group-hover:bg-white rounded-full"></div>
        </div>

        <!-- Right Panel: Output -->
        <div id="right-panel" class="h-full flex-1 min-w-0 flex flex-col border border-slate-800 rounded-xl shadow-2xl bg-slate-900">
            <div class="px-5 py-3 bg-slate-800/50 flex justify-between items-center border-b border-slate-700/50 shrink-0">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                    <span class="text-[9pt] text-slate-400 font-mono tracking-widest uppercase">Live Prompt Output</span>
                </div>
                <button id="copy-btn" class="group flex items-center gap-2 text-[10.5pt] font-bold bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-1.5 rounded-lg transition-all active:scale-95 shadow-lg shadow-indigo-900/20">
                    <i data-lucide="copy" class="w-4 h-4 group-active:scale-110"></i> 
                    <span id="copy-text">複製指令</span>
                </button>
            </div>
            <div class="p-6 overflow-y-auto flex-grow scrollbar-thin">
                <pre id="prompt-output" class="whitespace-pre-wrap text-[11pt] text-indigo-100/80 leading-relaxed font-mono selection:bg-indigo-500/30"></pre>
            </div>
        </div>
    </main>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        // 智慧建議對應表
        const TYPE_DEFAULTS = {
            youtube: { role: 'psycho', structure: 'aida', tone: 'humor', audience: 'public', format: 'transcript', requirements: ['hook', 'visual', 'gold-sentence'], wordCount: 'long' },
            outline: { role: 'strategist', structure: 'pyramid', tone: 'professional', audience: 'execs', format: 'framework', requirements: ['data-driven', 'gold-sentence'], wordCount: 'framework' },
            script: { role: 'mkt-strategist', structure: 'scqa', tone: 'epic', audience: 'public', format: 'dual-col', requirements: ['hook', 'visual'], wordCount: 'flexible' },
            project: { role: 'mkt-strategist', structure: 'problem-solution', tone: 'professional', audience: 'investor', format: 'slide-pages', requirements: ['data-driven', 'cta'], wordCount: 'long' },
            course: { role: 'lecturer', structure: 'golden-circle', tone: 'inspiring', audience: 'layman', format: 'slide-pages', requirements: ['analogy', 'cta'], wordCount: 'long' },
            social: { role: 'psycho', structure: 'aida', tone: 'provoke', audience: 'public', format: 'threads', requirements: ['hook', 'gold-sentence'], wordCount: 'short' },
            copy: { role: 'sales', structure: 'pastor', tone: 'empathy', audience: 'prospect', format: 'framework', requirements: ['hook', 'cta', 'data-driven'], wordCount: 'medium' },
            infographic: { role: 'tech', structure: 'problem-solution', tone: 'inspiring', audience: 'public', format: 'slide-pages', requirements: ['visual', 'gold-sentence'], wordCount: 'short' },
            investor_deck: { role: 'biz-analyst', structure: 'pyramid', tone: 'professional', audience: 'investor', format: 'slide-pages', requirements: ['data-driven', 'cta'], wordCount: 'medium' },
            report_deck: { role: 'biz-analyst', structure: 'pyramid', tone: 'objective', audience: 'execs', format: 'slide-pages', requirements: ['data-driven', 'visual'], wordCount: 'medium' }
        };

        const CONFIG = {
            infographics: [
                { id: 'info1', label: '懶人包 1 (極簡)', prompt: '【結構風格：懶人包 1】請採取條列式重點、直觀對比、極簡視覺指引風格。' },
                { id: 'info2', label: '懶人包 2 (引導)', prompt: '【結構風格：懶人包 2】請採取步驟引導、圖文交錯、核心行動導向風格。' },
                { id: 'info3', label: '懶人包 3 (數據)', prompt: '【結構風格：懶人包 3】請採取數據驅動、資訊圖表化、深度解析風格。' },
                { id: 'info4', label: '懶人包 4 (敘事)', prompt: '【結構風格：懶人包 4】請採取故事化敘事、情感共鳴、情境引導風格。' },
                { id: 'info5', label: '懶人包 5 (犀利)', prompt: '【結構風格：懶人包 5】請採取挑戰傳統、犀利反思、強烈對比風格。' },
                { id: 'info6', label: '懶人包 6 (對策)', prompt: '【結構風格：懶人包 6】請採取 FAQ 問答式、解決痛點、快速對策風格。' }
            ],
            types: [
                { id: 'youtube', label: 'YT 流量企劃', prompt: '你是一位百萬訂閱影音策略大師。請規劃一份高點閱潛力、高留存率的影片企劃。' },
                { id: 'outline', label: '簡報製作', prompt: '你是一位專業策略顧問。請生成一份邏輯嚴密、結構完整的簡報大綱與視覺建議。' },
                { id: 'script', label: '影音腳本', prompt: '你是一位資深編劇。請規劃一份節奏感強、適合拍攝的腳本。' },
                { id: 'project', label: '行銷企劃', prompt: '你是一位資深企劃經理。請撰寫一份具備可行性與目標明確的商業或行銷專案企劃。' },
                { id: 'course', label: '教學簡報', prompt: '你是一位教學設計專家。請設計一套針對教學目標、循序漸進的教學簡報大綱。' },
                { id: 'social', label: '社群貼文', prompt: '你是一位社群行銷專家。請規劃具備高互動潛力、符合社群語境的貼文。' },
                { id: 'copy', label: '產品文案', prompt: '你是一位王牌文案人。請設計一份強調賣點轉化、解決痛點的銷售架構。' },
                { id: 'infographic', label: '懶人包', prompt: '你是一位資訊圖表專家。請設計一份資訊高度濃縮、視覺引導強烈的懶人包架構。' },
                { id: 'investor_deck', label: '投資人簡報', prompt: '你是一位資深融資顧問。針對投資人需求，聚焦市場規模、商業模式與競爭壁壘規劃簡報大綱。' },
                { id: 'report_deck', label: '報告型簡報', prompt: '你是一位商業分析師。規劃一份以數據為核心、結論導向的專業報告型簡報大綱。' }
            ],
            roles: [
                { id: 'strategist', label: '策略顧問', prompt: '你擅長結構化思維與商業邏輯拆解。' },
                { id: 'lecturer', label: '學術教授', prompt: '你擅長將複雜知識拆解為易於吸收的教學體系。' },
                { id: 'sales', label: '提案專家', prompt: '你擅長抓住痛點並提出極具說服力的方案。' },
                { id: 'psycho', label: '心理大師', prompt: '你擅長分析受眾認知偏誤與情緒觸點。' },
                { id: 'tech', label: '技術專家', prompt: '你擅長精確描述底層原理與技術架構。' },
                { id: 'mkt-strategist', label: '行銷策略師', prompt: '你擅長品牌定位、市場切入點分析與行為洞察。' },
                { id: 'biz-analyst', label: '商業分析師', prompt: '你擅長數據建模、獲利模式評估與趨勢研判。' }
            ],
            structures: [
                { id: 'scqa', label: 'SCQA', prompt: '使用 SCQA 架構。' },
                { id: 'pyramid', label: '金字塔', prompt: '採取「結論先行」原則。' },
                { id: 'fab', label: 'FAB', prompt: '使用特性、優勢、利益邏輯。' },
                { id: 'aida', label: 'AIDA', prompt: '遵循注意、興趣、慾望、行動路徑。' },
                { id: 'pastor', label: 'PASTOR', prompt: '使用問題、放大、解決、轉化、回應架構。' },
                { id: 'golden-circle', label: '黃金圈', prompt: '使用 Why-How-What 核心動機架構。' },
                { id: 'problem-solution', label: '問題解決', prompt: '以「痛點分析 -> 解決 -> 效益」編排。' }
            ],
            tones: [
                { id: 'professional', label: '專業嚴謹', prompt: '文字必須嚴謹、權威且具備邏輯性。' },
                { id: 'empathy', label: '溫暖共情', prompt: '語氣柔和且具備同理心。' },
                { id: 'inspiring', label: '啟發鼓舞', prompt: '語氣帶有願景感，旨在激發熱情。' },
                { id: 'humor', label: '幽默風趣', prompt: '輕鬆幽默，加入適當流行梗。' },
                { id: 'objective', label: '客觀中立', prompt: '採取第三方中立視角。' },
                { id: 'provoke', label: '犀利反思', prompt: '大膽質疑現狀，語氣犀利。' },
                { id: 'epic', label: '史詩劇情', prompt: '語氣宏大、富有戲劇張力。' }
            ],
            audiences: [
                { id: 'execs', label: '高階決策', prompt: '跳過細節，直擊「成本與風險」，給結論與行動方針。' },
                { id: 'investor', label: '投資方', prompt: '強調護城河與獲利模型，數據說話，展現市場爆發力。' },
                { id: 'layman', label: '入門新手', prompt: '用「大白話」解釋，嚴禁專業術語，多用生活化案例。' },
                { id: 'tech-peer', label: '業內專家', prompt: '深挖底層原理，拒絕空泛虛詞，以技術參數為核心。' },
                { id: 'public', label: '一般大眾', prompt: '結合時事共鳴點，語氣親民，提供實用價值。' },
                { id: 'prospect', label: '潛在客戶', prompt: '鎖定現有痛點，提出具體解方，強化信任感並催促行動。' }
            ],
            requirements: [
                { id: 'hook', label: '吸引 Hook', prompt: '開場包含一個極具衝擊力的 Hook。' },
                { id: 'gold-sentence', label: '金句提煉', prompt: '提煉出具備傳播力的短金句。' },
                { id: 'analogy', label: '生活類比', prompt: '使用一個生活化的類比解釋複雜概念。' },
                { id: 'data-driven', label: '數據支撐', prompt: '預留「關鍵數據支撐」位置。' },
                { id: 'visual', label: '視覺建議', prompt: '標註視覺呈現方式與構圖細節。' },
                { id: 'cta', label: '行動 CTA', prompt: '結尾具備明確的行動呼籲。' }
            ],
            formats: [
                { id: 'slide-pages', label: '簡報分頁', prompt: '以「投影片 [編號]：[標題]」格式呈現。' },
                { id: 'dual-col', label: '雙欄腳本', prompt: '使用表格呈現，含畫面與旁白稿。' },
                { id: 'threads', label: '貼文串', prompt: '拆解為適合社群的系列短文。' },
                { id: 'transcript', label: '逐字稿', prompt: '擴展為包含語助詞、轉場語的逐字稿。' },
                { id: 'table', label: '表格清單', prompt: '使用 Markdown 表格輸出關鍵論點。' }
            ],
            wordCounts: [
                { id: 'short', label: '短篇 500', prompt: '控制在約 500 字。' },
                { id: 'medium', label: '中篇 1K', prompt: '提供約 1000 字深度。' },
                { id: 'long', label: '長篇 2K', prompt: '總字數達 2000 字左右。' },
                { id: 'framework', label: '完整框架', prompt: '輸出包含章節標題與核心論點的完整框架。' }
            ],
            visualStyles: [
                { id: 'minimal', label: '極簡白', visual: '純白背景、極大留白、現代黑體、冷灰色調。' },
                { id: 'premium', label: '商務質感', visual: '深藍背景、燙金配色、高品質寫實配圖、沉穩嚴謹。' },
                { id: 'tech', label: '科技現代', visual: '黑色背景、螢光藍綠、等距視角圖（Isometrics）、未來感。' },
                { id: 'fresh', label: '自然清新', visual: '米白或淺綠背景、莫蘭迪色系、具備呼吸感的排版。' },
                { id: 'playful', label: '創意活潑', visual: '大膽拼貼配色、大量幾何形狀、大字體設計、充滿能量感。' }
            ]
        };

        let auth = null;
        try {
            if (typeof __firebase_config !== 'undefined') {
                const firebaseConfig = JSON.parse(__firebase_config);
                const app = initializeApp(firebaseConfig);
                auth = getAuth(app);
            }
        } catch (e) { console.warn("Local Mode Active."); }

        // State Management
        let state = {
            smartEnabled: true,
            infographic: null, type: null, role: null, structure: null,
            tone: null, audience: null, format: null, wordCount: null,
            visualStyle: null, requirements: []
        };
        let title = '';
        let customNotes = '';

        const elements = {
            container: document.getElementById('selection-groups-container'),
            titleInput: document.getElementById('title-input'),
            notesInput: document.getElementById('custom-notes-input'),
            output: document.getElementById('prompt-output'),
            copyBtn: document.getElementById('copy-btn'),
            resetBtn: document.getElementById('reset-all-btn'),
            charCount: document.getElementById('title-char-count')
        };

        const buildPrompt = () => {
            const defaultH = "你是一位內容策略專家。請根據以下設定，為我規劃內容架構。";
            let p = `${state.type?.prompt || defaultH}\n\n`;
            
            if (state.infographic) p += `${state.infographic.prompt}\n\n`;
            if (title.trim()) p += `# 主題與目標\n"${title.trim()}"\n\n`;
            if (state.role) p += `# 角色設定\n${state.role.prompt}\n\n`;
            if (state.structure) p += `# 邏輯架構\n${state.structure.prompt}\n\n`;
            
            let details = "";
            if (state.tone) details += `- 語氣：${state.tone.prompt}\n`;
            if (state.audience) details += `- 受眾：${state.audience.prompt}\n`;
            if (state.wordCount) details += `- 篇幅要求：${state.wordCount.prompt}\n`;
            if (details) p += `# 策略細節\n${details}\n`;
            
            if (state.requirements.length > 0) {
                p += `# 組成要求\n${state.requirements.map(r => `- ${r.prompt}`).join('\n')}\n\n`;
            }

            if (customNotes.trim()) p += `# 補充細節\n${customNotes.trim()}\n\n`;
            if (state.format) p += `# 格式規範\n${state.format.prompt}\n\n`;
            
            p += `請輸出完整且具備深度洞察的內容框架。\n`;
            if (state.visualStyle) p += `\n//視覺風格建議：${state.visualStyle.label} (${state.visualStyle.visual})`;
            
            elements.output.textContent = p.trim();
        };

        const applySmartDefaults = (typeId) => {
            if (!state.smartEnabled) return;
            const d = TYPE_DEFAULTS[typeId];
            if (!d) return;

            state.role = CONFIG.roles.find(r => r.id === d.role) || null;
            state.structure = CONFIG.structures.find(s => s.id === d.structure) || null;
            state.tone = CONFIG.tones.find(t => t.id === d.tone) || null;
            state.audience = CONFIG.audiences.find(a => a.id === d.audience) || null;
            state.format = CONFIG.formats.find(f => f.id === d.format) || null;
            state.wordCount = CONFIG.wordCounts.find(w => w.id === d.wordCount) || null;
            state.requirements = CONFIG.requirements.filter(r => d.requirements.includes(r.id));
        };

        const render = () => {
            elements.container.innerHTML = '';
            const groups = [
                { label: "懶人包快選 (快速架構)", key: "infographics", stateKey: "infographic", clearAll: true },
                { label: "0. 內容類型", key: "types", stateKey: "type", hasToggle: true },
                { label: "1. 角色設定", key: "roles", stateKey: "role" },
                { label: "2. 邏輯架構", key: "structures", stateKey: "structure" },
                { label: "3. 語氣風格", key: "tones", stateKey: "tone" },
                { label: "4. 目標受眾", key: "audiences", stateKey: "audience" },
                { label: "5. 加分項目 (可複選)", key: "requirements", stateKey: "requirements", multi: true },
                { label: "6. 限定輸出格式", key: "formats", stateKey: "format" },
                { label: "7. 文字篇幅限制", key: "wordCounts", stateKey: "wordCount" },
                { label: "8. 視覺配色風格", key: "visualStyles", stateKey: "visualStyle" }
            ];

            groups.forEach(g => {
                const section = document.createElement('div');
                const header = document.createElement('div');
                header.className = 'flex items-center justify-between mb-3';
                
                header.innerHTML = `<h3 class="text-[10pt] font-bold text-slate-400 uppercase tracking-widest">${g.label}</h3>`;
                
                if (g.hasToggle) {
                    const toggle = document.createElement('label');
                    toggle.className = 'smart-toggle';
                    toggle.innerHTML = `<input type="checkbox" class="w-4 h-4 accent-indigo-600 cursor-pointer" ${state.smartEnabled ? 'checked' : ''}> 智慧建議`;
                    toggle.querySelector('input').onchange = (e) => state.smartEnabled = e.target.checked;
                    header.appendChild(toggle);
                }

                if (g.clearAll) {
                    const clear = document.createElement('button');
                    clear.className = 'text-[9pt] font-bold text-orange-500 hover:text-orange-600 flex items-center gap-1';
                    clear.innerHTML = `<i data-lucide="eraser" class="w-3.5 h-3.5"></i> 清除選取`;
                    clear.onclick = () => {
                        state = { ...state, infographic: null, type: null, role: null, structure: null, tone: null, audience: null, format: null, wordCount: null, visualStyle: null, requirements: [] };
                        elements.titleInput.value = elements.notesInput.value = title = customNotes = '';
                        render(); buildPrompt();
                    };
                    header.appendChild(clear);
                }

                const grid = document.createElement('div');
                grid.className = 'flex flex-wrap gap-2';

                CONFIG[g.key].forEach(opt => {
                    const isActive = g.multi ? state.requirements.some(r => r.id === opt.id) : state[g.stateKey]?.id === opt.id;
                    const btn = document.createElement('button');
                    btn.className = `selection-btn px-4 py-2 rounded-xl border text-[10.5pt] transition-all ${isActive ? 'active' : ''}`;
                    btn.textContent = opt.label;
                    btn.onclick = () => {
                        if (g.key === "types") {
                            state.type = state.type?.id === opt.id ? null : opt;
                            if (state.type) applySmartDefaults(opt.id);
                        } else if (g.multi) {
                            const idx = state.requirements.findIndex(r => r.id === opt.id);
                            idx > -1 ? state.requirements.splice(idx, 1) : state.requirements.push(opt);
                        } else {
                            state[g.stateKey] = state[g.stateKey]?.id === opt.id ? null : opt;
                        }
                        render(); buildPrompt();
                    };
                    grid.appendChild(btn);
                });

                section.append(header, grid);
                elements.container.appendChild(section);
            });
            lucide.createIcons();
        };

        // Event Listeners
        elements.titleInput.oninput = (e) => { 
            title = e.target.value; 
            elements.charCount.textContent = `${title.length} chars`;
            buildPrompt(); 
        };
        elements.notesInput.oninput = (e) => { customNotes = e.target.value; buildPrompt(); };
        
        elements.copyBtn.onclick = async () => {
            try {
                await navigator.clipboard.writeText(elements.output.textContent);
            } catch (err) {
                const el = document.createElement('textarea');
                el.value = elements.output.textContent;
                document.body.appendChild(el); el.select();
                document.execCommand('copy'); document.body.removeChild(el);
            }
            const btnText = document.getElementById('copy-text');
            const original = btnText.innerText;
            btnText.innerText = '已複製！';
            elements.copyBtn.classList.replace('bg-indigo-600', 'bg-green-600');
            setTimeout(() => {
                btnText.innerText = original;
                elements.copyBtn.classList.replace('bg-green-600', 'bg-indigo-600');
            }, 2000);
        };

        elements.resetBtn.onclick = () => { if(confirm("確定要重置所有設定嗎？")) location.reload(); };

        // Resizer Logic
        const resizer = document.getElementById('resizer');
        const leftPanel = document.getElementById('left-panel');
        let isResizing = false;
        resizer.onmousedown = () => isResizing = true;
        document.onmousemove = (e) => {
            if (!isResizing) return;
            const containerWidth = document.getElementById('container').offsetWidth;
            const newWidth = (e.clientX / containerWidth) * 100;
            if (newWidth > 20 && newWidth < 85) leftPanel.style.flexBasis = `${newWidth}%`;
        };
        document.onmouseup = () => isResizing = false;

        const init = async () => {
            if (auth) {
                await signInAnonymously(auth);
                onAuthStateChanged(auth, () => { render(); buildPrompt(); });
            } else { render(); buildPrompt(); }
        };
        init();
    </script>
</body>
</html>
